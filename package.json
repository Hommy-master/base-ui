{
  "name": "base-ui",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.23.0",
    "@ant-design/icons": "^5.5.0",
    "antd": "^5.22.2",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-gtm-module": "^2.0.11",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.20.1",
    "valtio": "^2.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "mockjs": "^1.1.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "sitemap": "^9.0.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-svgr": "^5.2.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock": "cross-env VITE_MOCK=true vite",
    "build": "pnpm clean:dist && pnpm generate-sitemap && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"*.{json,md,html,mjs}\" \".*rc.cjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"*.{json,md,html,mjs}\" \".*rc.cjs\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "clean:dist": "rimraf dist",
    "clean:cache": "rimraf node_modules/.cache/ && rimraf node_modules/.vite",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
