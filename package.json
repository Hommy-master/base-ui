{
  "name": "base-ui",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.2.5",
    "antd": "^6.4.4",
    "axios": "^1.18.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "lodash-es": "^4.17.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-gtm-module": "^2.0.11",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0",
    "valtio": "^2.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20.17.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "@vitest/ui": "^2.0.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "mockjs": "^1.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "sitemap": "^9.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^5.4.11",
    "vitest": "^2.0.0",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.3"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock": "cross-env VITE_MOCK=true vite",
    "build": "pnpm clean:dist && pnpm generate-sitemap && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"*.{json,md,html,mjs}\" \".*rc.cjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"*.{json,md,html,mjs}\" \".*rc.cjs\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "validate": "pnpm lint && pnpm lint:css && pnpm typecheck && pnpm test:run",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "clean:dist": "rimraf dist",
    "clean:cache": "rimraf node_modules/.cache/ && rimraf node_modules/.vite",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
