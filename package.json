    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "million": "^3.1.11",
    "mockjs": "^1.1.0",
    "prettier": "^3.5.3",
